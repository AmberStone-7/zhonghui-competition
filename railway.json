{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python", "node"]
    }
  },
  "deploy": {
    "startCommand": "cd backend && bash startup.sh",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}

